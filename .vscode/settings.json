{
    "chat.tools.terminal.autoApprove": {
        "dotnet build": true,
        "dotnet clean": true,
        "dotnet publish": true,
        "dotnet restore": true,
        "dotnet test": true,
        ".\\scripts\\Invoke-SystemTests.ps1": true,
        "gh": true,
        "Test-Path": true,
        "Get-Command": true,
        "ForEach-Object": true,
        "Get-ChildItem": true,
        "Get-Help": true,
    },
    "FSharp.suggestGitignore": false,
    "pester.runTestsInNewProcess": true,
    "xml.fileAssociations": [
        {
            "pattern": "**/PowerCode.Git.Format.ps1xml",
            "systemId": "https://raw.githubusercontent.com/PowerShell/PowerShell/refs/heads/master/src/Schemas/Format.xsd"
        }
    ],
    "awesome-copilot-sync.repositories": [
        {
            "label": "powercode/awesome-copilot",
            "repository": "powercode/awesome-copilot",
            "branch": "main"
        }
    ]
}